export default function handler(req, res) {
  const { token } = req.query;

  if (!token) {
    return res.status(400).json({ valid: false });
  }

  global.validTokens = global.validTokens || {};

  const record = global.validTokens[token];

  if (!record) {
    return res.status(401).json({ valid: false });
  }

  // OPTIONAL: expire after 10 minutes
  const isExpired = Date.now() - record.createdAt > 10 * 60 * 1000;

  if (isExpired) {
    delete global.validTokens[token];
    return res.status(401).json({ valid: false });
  }

  return res.status(200).json({ valid: true, phone: record.phone });
}
